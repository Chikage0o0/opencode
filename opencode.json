{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "disable": true,
      "options": {},
      "permission": {}
    },
    "plan": {
      "disable": true,
      "options": {},
      "permission": {}
    },
    "explore": {
      "disable": true,
      "options": {},
      "permission": {}
    },
    "general": {
      "disable": true,
      "options": {},
      "permission": {}
    },
    "orchestrator": {
      "description": "AI coding orchestrator that plans, delegates, reconciles, and verifies specialist work",
      "mode": "primary",
      "model": "openai/gpt-5.6-sol",
      "variant": "high",
      "prompt": "{file:./prompts/agents/orchestrator.md}",
      "permission": {
        "question": "allow",
        "task": {
          "*": "deny",
          "oracle": "allow",
          "librarian": "allow",
          "explorer": "allow",
          "designer": "allow",
          "fixer": "allow",
          "git-commit": "allow"
        },
        "skill": {
          "*": "allow",
          "make-interfaces-feel-better": "deny",
          "frontend-design": "deny"
        },
        "context7_*": "deny",
        "gh_grep_*": "deny",
        "websearch": "deny",
        "websearch_*": "deny",
        "cancel_task": "allow",
        "compress": "allow",
        "decompress": "allow",
        "prune": "allow",
        "search_context": "allow",
        "acp_status": "allow",
        "acp_context_recap": "allow"
      }
    },
    "oracle": {
      "description": "Strategic technical advisor for architecture, complex debugging, code review, and simplification",
      "mode": "subagent",
      "model": "openai/gpt-5.6-sol",
      "variant": "xhigh",
      "prompt": "{file:./prompts/agents/oracle.md}",
      "permission": {
        "*": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "question": "deny",
        "compress": "allow",
        "decompress": "allow",
        "prune": "allow",
        "search_context": "allow",
        "acp_status": "allow",
        "acp_context_recap": "allow",
        "skill": {
          "*": "deny",
          "codebase-design": "allow",
          "diagnosing-bugs": "allow",
          "web-perf": "allow"
        },
        "codegraph_*": "allow",
        "chrome-devtools_*": "allow"
      }
    },
    "librarian": {
      "description": "External documentation and library research specialist for official docs, examples, and upstream internals",
      "mode": "subagent",
      "model": "zhipuai-coding-plan/glm-5.2",
      "variant": "default",
      "prompt": "{file:./prompts/agents/librarian.md}",
      "permission": {
        "*": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "question": "deny",
        "webfetch": "allow",
        "websearch": "allow",
        "compress": "allow",
        "decompress": "allow",
        "prune": "allow",
        "search_context": "allow",
        "acp_status": "allow",
        "acp_context_recap": "allow",
        "skill": {
          "*": "deny",
          "research": "allow"
        },
        "context7_*": "allow",
        "gh_grep_*": "allow",
        "websearch_*": "allow",
        "chrome-devtools_*": "allow"
      }
    },
    "explorer": {
      "description": "Fast read-only codebase search and pattern matching specialist",
      "mode": "subagent",
      "model": "zhipuai-coding-plan/glm-5.2",
      "variant": "default",
      "prompt": "{file:./prompts/agents/explorer.md}",
      "permission": {
        "*": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "question": "deny",
        "compress": "allow",
        "decompress": "allow",
        "prune": "allow",
        "search_context": "allow",
        "acp_status": "allow",
        "acp_context_recap": "allow",
        "skill": "deny",
        "codegraph_*": "allow"
      }
    },
    "designer": {
      "description": "UI/UX design, review, and implementation specialist for visual and interaction quality",
      "mode": "subagent",
      "model": "xai/grok-4.5",
      "variant": "high",
      "prompt": "{file:./prompts/agents/designer.md}",
      "permission": {
        "*": "deny",
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "allow",
        "lsp": "allow",
        "question": "deny",
        "compress": "allow",
        "decompress": "allow",
        "prune": "allow",
        "search_context": "allow",
        "acp_status": "allow",
        "acp_context_recap": "allow",
        "skill": {
          "*": "deny",
          "make-interfaces-feel-better": "allow",
          "frontend-design": "allow",
          "svelte-code-writer": "allow",
          "shadcn-svelte": "allow"
        },
        "codegraph_*": "allow",
        "chrome-devtools_*": "allow"
      }
    },
    "fixer": {
      "description": "Fast implementation specialist for bounded, well-specified code changes",
      "mode": "subagent",
      "model": "xai/grok-4.5",
      "variant": "high",
      "prompt": "{file:./prompts/agents/fixer.md}",
      "permission": {
        "*": "deny",
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "allow",
        "lsp": "allow",
        "question": "deny",
        "compress": "allow",
        "decompress": "allow",
        "prune": "allow",
        "search_context": "allow",
        "acp_status": "allow",
        "acp_context_recap": "allow",
        "skill": {
          "*": "deny",
          "tdd": "allow",
          "diagnosing-bugs": "allow",
          "svelte-code-writer": "allow",
          "shadcn-svelte": "allow"
        },
        "codegraph_*": "allow"
      }
    },
    "git-commit": {
      "model": "zhipuai-coding-plan/glm-5.2",
      "variant": "default",
      "options": {},
      "permission": {
        "question": "deny",
        "compress": "allow",
        "decompress": "allow",
        "prune": "allow",
        "search_context": "allow",
        "acp_status": "allow",
        "acp_context_recap": "allow"
      }
    },
    "adversarial-author": {
      "model": "zhipuai-coding-plan/glm-5.2",
      "variant": "high",
    },
    "adversarial-reviewer": {
      "model": "openai/gpt-5.6-sol",
      "variant": "xhigh"
    },
    "title": {
      "model": "zhipuai-coding-plan/glm-4.7",
      "variant": "low",
      "options": {},
      "permission": {},
      "prompt": "你是对话标题生成助手。根据当前对话内容生成一个简短、准确的中文标题。\n\n规则：\n1. 只输出标题本身，不要解释、标点、引号、Markdown 或换行。\n2. 标题使用中文，长度 4-10 个汉字为佳，最多不超过 12 个汉字。\n3. 优先概括用户最新且明确的主要意图，而不是历史背景。\n4. 使用“对象 + 动作”或“问题 + 处理”结构，例如：模型配置、权限放开、提交配置、问题排查。\n5. 保留必要英文技术名词，如 OpenCode、Git、API、MCP、TDD。\n6. 不包含 token、API key、路径中的隐私信息、账号或其他敏感内容。\n7. 避免“关于、讨论、总结、帮助、如何”等空泛词。\n8. 如果意图不明确，输出：未命名对话。"
    }
  },
  "autoupdate": false,
  "compaction": {
    "auto": false,
    "tail_turns": 12,
    "prune": true
  },
  "default_agent": "orchestrator",
  "lsp": false,
  "model": "openai/gpt-5.6-sol",
  "permission": {
    "*": "allow",
    "cancel_task": "deny",
    "compress": "allow",
    "decompress": "allow",
    "prune": "allow",
    "search_context": "allow",
    "acp_status": "allow",
    "acp_context_recap": "allow"
  },
  "plugin": [
    "opencode-direnv"
  ],
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "oauth": false
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true,
      "oauth": false
    },
    "websearch": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa",
      "enabled": true,
      "oauth": false
    }
  },
  "share": "disabled",
  "small_model": "zhipuai-coding-plan/glm-4.7",
  "tool_output": {
    "max_lines": 800,
    "max_bytes": 24000
  },
  "disabled_providers": [],
  "experimental": {
    "primary_tools": [
      "cancel_task"
    ]
  }
}
