{
  "$schema": "https://unpkg.com/oh-my-opencode-slim@2.1.1/oh-my-opencode-slim.schema.json",
  "preset": "default",
  "autoUpdate": false,
  "presets": {
    "default": {
      "orchestrator": {
        "model": "openai/gpt-5.6-sol",
        "variant": "medium",
        "skills": ["*", "!make-interfaces-feel-better", "!frontend-design"],
        "mcps": ["*", "!context7", "!gh_grep", "!websearch"]
      },
      "oracle": {
        "model": "openai/gpt-5.6-sol",
        "variant": "high",
        "skills": ["codebase-design", "diagnosing-bugs", "web-perf"],
        "mcps": ["codegraph", "chrome-devtools"]
      },
      "librarian": {
        "model": "openai/gpt-5.6-luna",
        "variant": "low",
        "skills": [],
        "mcps": ["context7", "gh_grep", "websearch", "chrome-devtools"]
      },
      "explorer": {
        "model": "openai/gpt-5.6-luna",
        "variant": "low",
        "skills": [],
        "mcps": ["codegraph"]
      },
      "designer": {
        "model": "openai/gpt-5.6-terra",
        "variant": "medium",
        "skills": [
          "make-interfaces-feel-better",
          "frontend-design",
          "svelte-code-writer",
          "shadcn-svelte"
        ],
        "mcps": ["codegraph", "chrome-devtools"]
      },
      "fixer": {
        "model": "openai/gpt-5.6-terra",
        "variant": "medium",
        "skills": [
          "test-driven-development",
          "diagnosing-bugs",
          "verification-before-completion",
          "svelte-code-writer",
          "shadcn-svelte"
        ],
        "mcps": ["codegraph"]
      }
    }
  },
  "disabled_agents": ["observer"]
}
