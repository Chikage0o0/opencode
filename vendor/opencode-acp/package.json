{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "opencode-acp",
    "version": "1.12.6",
    "private": true,
    "type": "module",
    "description": "Locally patched opencode-acp 1.12.6 source package for session-safe OpenCode integration",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./server": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "x-upstream": {
        "repository": "https://github.com/ranxianglei/opencode-acp.git",
        "tag": "v1.12.6",
        "commit": "f1a33d9f4ce55af808eb4e050717c914ed16084b"
    },
    "x-local-patches": [
        "Per-session write ordering, atomic replacement, and terminal-failure draining",
        "Single-flight storage initialization and race-safe legacy state migration",
        "Dispose-time draining scoped to the active session"
    ],
    "keywords": [
        "opencode",
        "opencode-plugin",
        "plugin",
        "context",
        "pruning",
        "active-context",
        "optimization",
        "tokens",
        "acp"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ranxianglei/opencode-acp.git"
    },
    "bugs": {
        "url": "https://github.com/ranxianglei/opencode-acp/issues"
    },
    "homepage": "https://github.com/ranxianglei/opencode-acp#readme",
    "author": "ranxianglei",
    "license": "AGPL-3.0-or-later",
    "peerDependencies": {
        "@opencode-ai/plugin": ">=1.16.0"
    },
    "dependencies": {
        "@anthropic-ai/tokenizer": "^0.0.4",
        "@opencode-ai/sdk": "^1.4.3",
        "jsonc-parser": "^3.3.1",
        "zod": "^4.3.6"
    },
    "files": [
        "dist/",
        "index.ts",
        "lib/",
        "README.md",
        "LICENSE"
    ]
}
